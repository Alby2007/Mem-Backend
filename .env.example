# Trading Galaxy — Environment Variables
# Copy this file to .env and fill in your values.
# docker-compose picks up .env automatically.

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite knowledge base inside the container.
# Default is /data/trading_knowledge.db (mapped to the kb-data Docker volume).
# Only change this if you are mounting the DB somewhere else.
# TRADING_KB_DB=/data/trading_knowledge.db

# ── Flask server ──────────────────────────────────────────────────────────────
# Port the API listens on. Exposed on the host at the same port by default.
# PORT=5050

# ── Ollama (LLM backend) ──────────────────────────────────────────────────────
# URL of the Ollama server.
# When using docker-compose, the sidecar service is automatically reachable
# at http://ollama:11434 — this is set in docker-compose.yml and you don't
# need to change it here unless you are running Ollama on a remote host.
# OLLAMA_BASE_URL=http://ollama:11434

# Model to use for chat completions. Must be pulled into Ollama first:
#   docker-compose exec ollama ollama pull llama3.2
# Other options: mistral, llama3.1, phi3, gemma2, etc.
OLLAMA_MODEL=llama3.2

# Model to use for structured atom extraction from news/filing text.
# Separate from OLLAMA_MODEL — extraction needs JSON compliance and speed
# more than reasoning depth. phi3 and qwen2.5:3b are good choices.
#   docker-compose exec ollama ollama pull phi3
OLLAMA_EXTRACTION_MODEL=phi3

# ── FRED (macroeconomic data) ─────────────────────────────────────────────────
# Free API key from https://fred.stlouisfed.org/docs/api/api_key.html
# If not set, the FRED adapter skips gracefully — all other adapters still run.
FRED_API_KEY=your_fred_api_key_here

# ── EIA (U.S. Energy Information Administration) ──────────────────────────────
# Free API key from https://api.eia.gov/registrations — instant approval.
# Provides WTI/Brent crude prices, US production, and inventory levels.
# Feeds directly into the causal shock engine for energy sector propagation.
EIA_API_KEY=your_eia_api_key_here

# ── ACLED (Armed Conflict Location & Event Data) ──────────────────────────────
# Free registration at https://acleddata.com/register/ (research use only).
# ⚠️  Non-commercial research license. Commercial license required for
#     production use with paying users — contact ACLED for pricing.
# If not set, the ACLED adapter skips gracefully.
# ACLED_API_KEY=your_acled_api_key_here
# ACLED_EMAIL=your_email@example.com

# ── SEC EDGAR (filings + insider transactions) ────────────────────────────────
# The SEC requires a User-Agent string identifying your application and contact.
# Format: "AppName contact@example.com"
# Default is acceptable for personal/dev use. Change for production.
# EDGAR_USER_AGENT=TradingGalaxyKB admin@tradinggalaxy.dev

# ── Telegram (daily briefing delivery) ───────────────────────────────────────
# Bot token from @BotFather (https://t.me/BotFather).
# Required for scheduled briefing delivery and POST /notify/test.
# If not set, the delivery scheduler runs but sends are skipped gracefully.
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Authentication (JWT) ──────────────────────────────────────────────────────
# 256-bit random secret for signing JWTs.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — the insecure dev default will be used if not set.
JWT_SECRET_KEY=change-me-generate-with-secrets.token_hex-32

# Access token lifetime in hours (default 24).
# JWT_EXPIRY_HOURS=24

# Refresh token lifetime in days (default 30). Refresh tokens are single-use
# (rotated on each /auth/refresh call). Set lower for higher-security environments.
# JWT_REFRESH_EXPIRY_DAYS=30

# ── Field-level encryption ────────────────────────────────────────────────────
# Fernet key for encrypting sensitive DB columns (telegram_chat_id, account_size, etc.)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, sensitive fields are stored as plaintext (acceptable for local dev only).
# DB_ENCRYPTION_KEY=your_fernet_key_here

# ── KB seed distribution (seed authority machine only) ────────────────────────
# GitHub Personal Access Token with "write:releases" scope.
# ONLY required on the machine that pushes seed updates (your live machine).
# Collaborator instances do NOT need this — seed downloads are public.
# Create at: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here
