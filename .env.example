# Trading Galaxy — Environment Variables
# Copy this file to .env and fill in your values.
# docker-compose picks up .env automatically.

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite knowledge base inside the container.
# Default is /data/trading_knowledge.db (mapped to the kb-data Docker volume).
# Only change this if you are mounting the DB somewhere else.
# TRADING_KB_DB=/data/trading_knowledge.db

# ── Flask server ──────────────────────────────────────────────────────────────
# Port the API listens on. Exposed on the host at the same port by default.
# PORT=5050

# ── Ollama (LLM backend) ──────────────────────────────────────────────────────
# URL of the Ollama server.
# When using docker-compose, the sidecar service is automatically reachable
# at http://ollama:11434 — this is set in docker-compose.yml and you don't
# need to change it here unless you are running Ollama on a remote host.
# OLLAMA_BASE_URL=http://ollama:11434

# Model to use for chat completions. Must be pulled into Ollama first:
#   docker-compose exec ollama ollama pull llama3.2
# Other options: mistral, llama3.1, phi3, gemma2, etc.
OLLAMA_MODEL=llama3.2

# Model to use for structured atom extraction from news/filing text.
# Separate from OLLAMA_MODEL — extraction needs JSON compliance and speed
# more than reasoning depth. phi3 and qwen2.5:3b are good choices.
#   docker-compose exec ollama ollama pull phi3
OLLAMA_EXTRACTION_MODEL=phi3

# ── FRED (macroeconomic data) ─────────────────────────────────────────────────
# Free API key from https://fred.stlouisfed.org/docs/api/api_key.html
# If not set, the FRED adapter skips gracefully — all other adapters still run.
# FRED_API_KEY=your_fred_api_key_here
FRED_API_KEY=

# ── SEC EDGAR (filings + insider transactions) ────────────────────────────────
# The SEC requires a User-Agent string identifying your application and contact.
# Format: "AppName contact@example.com"
# Default is acceptable for personal/dev use. Change for production.
# EDGAR_USER_AGENT=TradingGalaxyKB admin@tradinggalaxy.dev
