# ── Trading Galaxy — Environment Variables ────────────────────────────────────
# Copy this to .env and fill in real values before starting the service.
# NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute path to the SQLite KB file (created automatically on first run)
TRADING_KB_DB=/opt/trading-galaxy/data/trading_knowledge.db

# ── API Server ────────────────────────────────────────────────────────────────
PORT=5050

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_64_char_hex_string
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# Optional: encrypt sensitive KB atoms at rest (Fernet key)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DB_ENCRYPTION_KEY=

# ── External data sources ─────────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# SEC EDGAR — identify your app (no key required, just a contact email)
EDGAR_USER_AGENT=TradingGalaxyKB your@email.com

# ── Notifications (optional) ──────────────────────────────────────────────────
# Telegram bot token — create via @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# Ollama runs on the same machine — default is fine
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EXTRACTION_MODEL=phi3
OLLAMA_VISION_MODEL=llava
OLLAMA_CHAT_TIMEOUT=180

# ── Governance (optional) ─────────────────────────────────────────────────────
# JARVIS_GOVERNANCE_MODE=static
