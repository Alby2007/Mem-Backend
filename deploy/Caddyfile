# deploy/Caddyfile
#
# Domain: api.tradinggalaxy.dev
# Caddy auto-provisions a Let's Encrypt TLS certificate — no certbot needed.
#
# To test with an IP only (no domain), replace the domain block with:
#   :80 { reverse_proxy trading-galaxy:5050 }

api.tradinggalaxy.dev {
    # Automatic HTTPS — Caddy handles ACME challenge and renewal
    tls {
        protocols tls1.2 tls1.3
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    # Rate-limit aggressive scrapers at the edge (belt-and-suspenders with
    # flask-limiter inside the app)
    rate_limit {
        zone dynamic {
            key    {remote_host}
            events 300
            window 1m
        }
    }

    # Proxy to gunicorn
    reverse_proxy trading-galaxy:5050 {
        health_uri     /health
        health_interval 15s
        health_timeout  5s

        # Pass real IP to Flask (used by flask-limiter)
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP       {remote_host}
        header_up Host            {host}
    }

    # Access log
    log {
        output file /var/log/caddy/access.log {
            roll_size     50mb
            roll_keep     5
            roll_keep_for 720h
        }
        format json
    }
}

# Redirect bare HTTP → HTTPS (Caddy handles this automatically, but
# explicit is clearer for ops review)
http://api.tradinggalaxy.dev {
    redir https://api.tradinggalaxy.dev{uri} permanent
}
